{
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/vyakti-parichay run build",
  "outputDirectory": "artifacts/vyakti-parichay/dist/public",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
